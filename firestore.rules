rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, userName, balance, role, createdAt
    //
    // Collection: deposits
    // Fields: uid, amount, method, trxId, status, createdAt
    //
    // Collection: withdrawals
    // Fields: uid, amount, method, accountNumber, status, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "ifaizul500@gmail.com"); // Default admin from context
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'userName', 'balance', 'role']) &&
             data.uid is string &&
             data.userName is string && data.userName.size() < 50 &&
             data.balance is number &&
             data.role in ['user', 'admin'];
    }

    function isValidDeposit(data) {
      return data.keys().hasAll(['uid', 'amount', 'method', 'trxId', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.method in ['bKash', 'Nagad'] &&
             data.trxId is string && data.trxId.size() < 100 &&
             data.status == 'pending';
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['uid', 'amount', 'method', 'accountNumber', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount >= 500 &&
             data.method in ['bKash', 'Nagad'] &&
             data.accountNumber is string && data.accountNumber.size() < 20 &&
             data.status == 'pending';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.balance == resource.data.balance);
    }

    match /deposits/{depositId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDeposit(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
